    border-bottom: none;
    border-radius: 6px 6px 0 0;
    padding: 7px 22px;
    font-size: 12px;
    min-width: 130px;
}
QTabBar::tab:selected {
    background: white;
    color: #0077ff;
    font-weight: bold;

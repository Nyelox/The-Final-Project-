}
QTabBar::tab:hover:!selected {
    background: #e0f0ff;
}
QTableWidget {
    background: white;
    border: 1px solid #d0e3ff;
    border-radius: 8px;
    gridline-color: #eef3ff;
    font-size: 12px;
    color: #222;
    selection-background-color: #d0e3ff;

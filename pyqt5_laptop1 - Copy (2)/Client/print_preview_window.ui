  <property name="styleSheet">
   <string notr="true">
QDialog#PrintPreviewWindow, QWidget {
    background-color: white;
    color: #222;
    font-family: "Segoe UI", Arial, sans-serif;
}
QScrollArea {
    background: transparent;
    border: none;
}
QScrollBar:vertical {
    background: #f0f0f0;
    width: 8px;
    border-radius: 4px;
}
QScrollBar::handle:vertical {
    background: #0077ff;
    border-radius: 4px;
    min-height: 30px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}
QLabel#label_title {
    color: #222;
    font-size: 16px;
    font-weight: bold;
}
QLabel#label_pages {
    color: #666;
    font-size: 11px;
}
QFrame#line_sep1, QFrame#line_sep2, QFrame#line_sep3 {
    color: #ccc;
}
QGroupBox#group_printer {
    color: #0077ff;
    border: 1px solid #ccc;
    border-radius: 10px;
    margin-top: 8px;
    font-size: 12px;
    font-weight: bold;
    padding: 10px 8px 8px 8px;
}
QGroupBox#group_printer::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 4px;
    color: #0077ff;
}
QRadioButton {
    color: #333;
    font-size: 12px;
    spacing: 6px;
}
QRadioButton::indicator {
    width: 16px;
    height: 16px;
}
QRadioButton::indicator:checked {
    background: #0077ff;
    border-radius: 8px;
    border: 2px solid #3399ff;
}
QRadioButton::indicator:unchecked {
    background: #f0f0f0;
    border-radius: 8px;
    border: 2px solid #ccc;
}
QComboBox {
    background: #f8fbff;
    color: #222;
    border: 1px solid #ccc;
    border-radius: 7px;
    padding: 5px 10px;
    font-size: 12px;
}
QComboBox::drop-down {
    border: none;
    width: 24px;
}
QComboBox QAbstractItemView {
    background: white;
    color: #222;
    selection-background-color: #0077ff;
    border: 1px solid #ccc;
}
QLineEdit {
    background: #f8fbff;
    color: #222;
    border: 1px solid #ccc;
    border-radius: 7px;
    padding: 5px 10px;
    font-size: 12px;
}
QLineEdit:disabled {
    color: #aaa;
    background: #f0f0f0;
}
QLabel#label_port {
    color: #555;
    font-size: 12px;
}
QPushButton#btn_print {
    background-color: #0077ff;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 13px;
    font-weight: bold;
}
QPushButton#btn_print:hover {
    background-color: #3399ff;
}
QPushButton#btn_print:pressed {
    background-color: #0055cc;
}
QPushButton#btn_print:disabled {
    background-color: #ccc;
    color: #888;
}
QPushButton#btn_close {
    background-color: #e6f2ff;
    color: #0077ff;
    border: 1px solid #d0e3ff;
    border-radius: 10px;
    font-size: 13px;
}
QPushButton#btn_close:hover {
    background-color: #cce6ff;
}
QScrollArea QFrame {
    background: #f8fbff;
    border: 1px solid #d0e3ff;
    border-radius: 6px;
}
   </string>

  <widget class="QWidget" name="centralwidget">
   <property name="styleSheet">
    <string notr="true">
QWidget#centralwidget {
    background-color: #f8faff;
    font-family: "Segoe UI", Roboto, Arial, sans-serif;
}
QGroupBox {
    background-color: white;
    border: 1px solid #e1e9f5;
    border-radius: 12px;
    margin-top: 15px;
    padding-top: 15px;
    font-weight: bold;
    color: #444;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    padding: 0 5px;
}
QLabel {
    color: #555;
    font-weight: 500;
}
QLineEdit, QSpinBox, QListWidget {
    background-color: white;
    border: 1px solid #dce4ec;
    border-radius: 6px;
    padding: 8px;
    color: #333;
    font-size: 13px;
}
QLineEdit:focus, QSpinBox:focus, QListWidget:focus {
    border: 2px solid #0077ff;
}
QPushButton {
    font-weight: bold;
    border-radius: 8px;
    padding: 10px 20px;
    font-size: 13px;
}
QPushButton#btn_send, QPushButton#btn_download, QPushButton#btn_select {
    background-color: #0077ff;
    color: white;
    border: none;
}
QPushButton#btn_send:hover, QPushButton#btn_download:hover, QPushButton#btn_select:hover {
    background-color: #0056cc;
}
QPushButton#btn_send:disabled {
    background-color: #a0c4ff;
}
QPushButton#btn_refresh {
    background-color: #f0f7ff;
    color: #0077ff;
    border: 1px solid #d0e3ff;
}
QPushButton#btn_refresh:hover {
    background-color: #e0f0ff;
}
QPushButton#btn_back {
    background-color: #f0f7ff;
    color: #0077ff;
    border: 1px solid #d0e3ff;
}
QPushButton#btn_back:hover {
    background-color: #e0f0ff;
}
QListWidget::item {
    padding: 10px;
    border-bottom: 1px solid #f0f4f8;
}
QListWidget::item:selected {
    background-color: #eef3ff;
    color: #0077ff;
}
</string>
